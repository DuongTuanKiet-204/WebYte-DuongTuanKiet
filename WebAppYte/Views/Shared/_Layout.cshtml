    <!-- AI CHATBOT -->
    <div id="ai-chat-toggle" title="Chatbot AI">
        💬
    </div>

    <div id="ai-chat-box">
        <div id="ai-chat-header">
            Chatbot AI hỗ trợ y tế
            <span id="ai-chat-close">×</span>
        </div>

        <div id="ai-chat-body">
            <div class="ai-bot-msg">
                Xin chào, tôi là chatbot AI hỗ trợ y tế cơ bản. Bạn có thể hỏi về triệu chứng thông thường, đặt lịch, trung tâm y tế, bác sĩ hoặc cách dùng website.
            </div>
        </div>

        <div id="ai-chat-suggestions">
            <button type="button" class="ai-chat-suggest" data-text="Tôi bị sốt thì nên làm gì?">Bị sốt</button>
            <button type="button" class="ai-chat-suggest" data-text="Tôi bị ho và đau họng thì sao?">Ho đau họng</button>
            <button type="button" class="ai-chat-suggest" data-text="Tôi muốn đặt lịch khám">Đặt lịch</button>
            <button type="button" class="ai-chat-suggest" data-text="Trung tâm y tế gần nhất ở đâu?">Trung tâm y tế</button>
        </div>

        <div id="ai-chat-footer">
            <input type="text" id="ai-chat-input" placeholder="Nhập câu hỏi..." />
            <button type="button" id="ai-chat-send">Gửi</button>
        </div>
    </div>

    <style>
        #ai-chat-toggle {
            position: fixed;
            right: 22px;
            bottom: 22px;
            width: 58px;
            height: 58px;
            border-radius: 50%;
            background: #007bff;
            color: #fff;
            font-size: 24px;
            text-align: center;
            line-height: 58px;
            cursor: pointer;
            z-index: 99999;
            box-shadow: 0 4px 12px rgba(0,0,0,.25);
        }

        #ai-chat-box {
            display: none;
            position: fixed;
            right: 22px;
            bottom: 92px;
            width: 360px;
            max-width: calc(100% - 24px);
            height: 500px;
            background: #fff;
            border: 1px solid #ddd;
            border-radius: 14px;
            overflow: hidden;
            z-index: 99999;
            box-shadow: 0 10px 30px rgba(0,0,0,.2);
        }

        #ai-chat-header {
            background: #007bff;
            color: white;
            padding: 12px 14px;
            font-weight: bold;
            position: relative;
        }

        #ai-chat-close {
            position: absolute;
            right: 14px;
            top: 7px;
            cursor: pointer;
            font-size: 24px;
        }

        #ai-chat-body {
            height: 325px;
            overflow-y: auto;
            padding: 12px;
            background: #f7f9fb;
        }

        .ai-bot-msg, .ai-user-msg {
            max-width: 85%;
            margin-bottom: 10px;
            padding: 10px 12px;
            border-radius: 12px;
            word-break: break-word;
            white-space: pre-line;
        }

        .ai-bot-msg {
            background: #e9ecef;
            color: #222;
            margin-right: auto;
        }

        .ai-user-msg {
            background: #d1ecf1;
            color: #222;
            margin-left: auto;
            text-align: right;
        }

        #ai-chat-suggestions {
            padding: 8px 10px;
            background: #fff;
            border-top: 1px solid #eee;
        }

        .ai-chat-suggest {
            margin: 3px;
            padding: 6px 10px;
            border: 1px solid #007bff;
            background: #fff;
            color: #007bff;
            border-radius: 16px;
            cursor: pointer;
            font-size: 12px;
        }

        #ai-chat-footer {
            display: flex;
            gap: 8px;
            padding: 10px;
            border-top: 1px solid #eee;
            background: #fff;
        }

        #ai-chat-input {
            flex: 1;
            padding: 8px 10px;
            border: 1px solid #ccc;
            border-radius: 8px;
            outline: none;
        }

        #ai-chat-send {
            padding: 8px 14px;
            border: none;
            background: #28a745;
            color: white;
            border-radius: 8px;
            cursor: pointer;
        }
    </style>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @Scripts.Render("~/bundles/fullcalendarjs")

    <script>
        $(function () {
            var $toggle = $("#ai-chat-toggle");
            var $box = $("#ai-chat-box");
            var $close = $("#ai-chat-close");
            var $body = $("#ai-chat-body");
            var $input = $("#ai-chat-input");
            var $send = $("#ai-chat-send");

            $toggle.on("click", function () {
                $box.toggle();
            });

            $close.on("click", function () {
                $box.hide();
            });

            function escapeHtml(text) {
                return $("<div>").text(text).html();
            }

            function appendUser(text) {
                $body.append('<div class="ai-user-msg">' + escapeHtml(text) + '</div>');
                scrollBottom();
            }

            function appendBot(text) {
                $body.append('<div class="ai-bot-msg">' + escapeHtml(text) + '</div>');
                scrollBottom();
            }

            function scrollBottom() {
                $body.scrollTop($body[0].scrollHeight);
            }

            function sendMessage(message) {
                if (!message || $.trim(message) === "") return;

                appendUser(message);
                $input.val("");

                $.ajax({
                    url: '@Url.Action("Ask", "Chatbot")',
                    type: 'POST',
                    data: { message: message },
                    success: function (res) {
                        if (res && res.success) {
                            appendBot(res.answer);
                        } else {
                            appendBot("Tôi chưa thể trả lời lúc này. Bạn vui lòng thử lại sau.");
                        }
                    },
                    error: function () {
                        appendBot("Không thể kết nối chatbot AI. Bạn vui lòng thử lại sau.");
                    }
                });
            }

            $send.on("click", function () {
                sendMessage($input.val());
            });

            $input.on("keypress", function (e) {
                if (e.which === 13) {
                    sendMessage($input.val());
                }
            });

            $(".ai-chat-suggest").on("click", function () {
                sendMessage($(this).data("text"));
            });
        });
    </script>

    @RenderSection("scripts", required: false)
</body>
</html>