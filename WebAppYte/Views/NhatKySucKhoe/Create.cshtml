@{
    ViewBag.Title = "Thêm nhật ký";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Thêm nhật ký sức khỏe</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <input type="hidden"
           name="IDNguoiDung"
           value="@ViewBag.IDNguoiDung" />

    <div class="form-group">
        <label>Nhiệt độ</label>
        <input type="number"
               step="0.1"
               name="NhietDo"
               class="form-control" />
    </div>

    <div class="form-group">
        <label>Triệu chứng</label>
        <textarea name="TrieuChung"
                  class="form-control"></textarea>
    </div>

    <div class="form-group">
        <label>Mức độ mệt (1-10)</label>
        <input type="number"
               name="MucDoMet"
               class="form-control" />
    </div>

    <div class="form-group">
        <label>Ghi chú</label>
        <textarea name="GhiChu"
                  class="form-control"></textarea>
    </div>

    <br />

    <button type="submit" class="btn btn-primary">
        Lưu nhật ký
    </button>
}