@model List<WebAppYte.Models.NhatKySucKhoeViewModel>

@{
    ViewBag.Title = "Nhật ký sức khỏe";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Nhật ký sức khỏe cá nhân</h2>

<p>
    <a class="btn btn-success"
       href="@Url.Action("Create", "NhatKySucKhoe", new { id = ViewBag.IDNguoiDung })">
        Thêm nhật ký
    </a>
</p>

<table class="table table-bordered">
    <tr>
        <th>Ngày nhập</th>
        <th>Nhiệt độ</th>
        <th>Triệu chứng</th>
        <th>Mức độ mệt</th>
        <th>Ghi chú</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>
                @(item.NgayNhap.HasValue
                    ? item.NgayNhap.Value.ToString("dd/MM/yyyy HH:mm")
                    : "")
            </td>

            <td>@item.NhietDo °C</td>

            <td>@item.TrieuChung</td>

            <td>@item.MucDoMet /10</td>

            <td>@item.GhiChu</td>
        </tr>
    }
</table>