@model PagedList.IPagedList<WebAppYte.Models.LichKham>
@using PagedList.Mvc;

@{
    ViewBag.Title = "Kiemtralichhen";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var userBS = Session["userBS"] as WebAppYte.Models.QuanTri;
    int idBacSi = userBS != null ? userBS.IDQuanTri : 0;
}

<hr />
<h2>DANH SÁCH LỊCH HẸN</h2>
<hr />

<h4>
    <a href="@Url.Action("Lichdangcho", "Bacsi", new { id = idBacSi })">LỊCH CHƯA XÁC NHẬN</a>&nbsp;||
    <a href="@Url.Action("Lichdaxacnhan", "Bacsi", new { id = idBacSi })">LỊCH ĐÃ XÁC NHẬN</a>&nbsp;||
    <a href="@Url.Action("Kiemtralichhen", "Bacsi", new { id = idBacSi })">TẤT CẢ LỊCH HẸN</a>
</h4>

<br />

<table class="table table-bordered">
    <tr>
        <th>Người đặt lịch</th>
        <th>Nội dung cần tư vấn</th>
        <th>Hẹn vào lúc</th>
        <th>Trạng thái</th>
        <th>Link ZOOM</th>
        <th>Ghi chú tư vấn</th>
        <th>Thao tác</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@Html.DisplayFor(modelItem => item.NguoiDung.HoTen)</td>

            <td>@Html.DisplayFor(modelItem => item.ChuDe)</td>

            <td>
                @if (item.BatDau != null)
                {
                    @item.BatDau.Value.ToString("dd/MM/yyyy HH:mm:ss")
                }
            </td>

            <td>
                @if (item.TrangThai == 0)
                {
                    <h5 style="color:red">Đang chờ xác nhận</h5>
                }
                else if (item.TrangThai == 1)
                {
                    <h5 style="color:green">Đã xác nhận lịch</h5>
                }
                else if (item.TrangThai == 2)
                {
                    <h5 style="color:goldenrod">Đã tư vấn xong</h5>
                }
                else
                {
                    <h5 style="color:red">Lỗi</h5>
                }
            </td>

            <td>
                @if (!string.IsNullOrEmpty(item.ZoomInfo))
                {
                    <a href="@item.ZoomInfo" target="_blank" class="btn btn-info btn-sm">
                        Mở Zoom
                    </a>
                }
                else
                {
                    <span style="color:red">Chưa có link</span>
                }
            </td>

            <td>@Html.DisplayFor(modelItem => item.KetQuaKham)</td>

            <td>
                @Html.ActionLink("Xác nhận / Sửa", "Xacnhanlichhen", new { id = item.IDLichKham }, new { @class = "btn btn-primary btn-sm" })

                <br /><br />

                @Html.ActionLink("Xem nhật ký", "BacsiXem", "NhatKySucKhoe",
                    new { idNguoiDung = item.IDNguoiDung },
                    new { @class = "btn btn-warning btn-sm" })
            </td>
        </tr>
    }
</table>

Trang @(Model.PageCount < Model.PageNumber ? 0 : Model.PageNumber) / @Model.PageCount

@Html.PagedListPager(Model, page => Url.Action("Kiemtralichhen", new { page }))