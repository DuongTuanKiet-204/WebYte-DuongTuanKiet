@model WebAppYte.Models.NguoiDung

@{
    ViewBag.Title = "Dangky";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background: linear-gradient(135deg, #eef7fb, #f7fbff);
    }

    .register-wrapper {
        min-height: 88vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px 15px;
    }

    .register-card {
        width: 100%;
        max-width: 700px;
        background: #fff;
        border-radius: 22px;
        box-shadow: 0 12px 35px rgba(0, 73, 122, 0.12);
        overflow: hidden;
        border: 1px solid #e7f1f8;
    }

    .register-header {
        background: linear-gradient(135deg, #1d8cf8, #00b5d8);
        color: white;
        text-align: center;
        padding: 30px 20px;
    }

        .register-header h2 {
            margin: 0;
            font-size: 32px;
            font-weight: 700;
        }

        .register-header p {
            margin-top: 8px;
            font-size: 14px;
            opacity: 0.95;
        }

    .register-body {
        padding: 30px 28px;
    }

    .form-group {
        margin-bottom: 18px;
    }

    .form-label {
        display: block;
        margin-bottom: 8px;
        font-weight: 600;
        color: #1f3b57;
    }

    .form-control {
        width: 100%;
        height: 46px;
        border-radius: 12px;
        border: 1px solid #cfe3f1;
        box-shadow: none;
        padding: 10px 14px;
        font-size: 15px;
    }

        .form-control:focus {
            border-color: #1d8cf8;
            box-shadow: 0 0 0 3px rgba(29, 140, 248, 0.12);
            outline: none;
        }

    .register-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
    }

    .btn-wrap {
        display: flex;
        gap: 12px;
        margin-top: 24px;
        flex-wrap: wrap;
    }

    .btn-submit {
        background: linear-gradient(135deg, #1d8cf8, #00b5d8);
        color: white;
        border: none;
        padding: 12px 24px;
        border-radius: 12px;
        font-size: 15px;
        font-weight: 600;
    }

        .btn-submit:hover {
            color: white;
            background: linear-gradient(135deg, #1878d7, #00a2c2);
        }

    .btn-back {
        background: #eef6fb;
        color: #1f5f8b;
        border: 1px solid #cfe3f1;
        padding: 12px 24px;
        border-radius: 12px;
        font-size: 15px;
        font-weight: 600;
        text-decoration: none;
    }

        .btn-back:hover {
            text-decoration: none;
            color: #124d77;
            background: #dff0fb;
        }

    .alert-error {
        background: #fff1f1;
        color: #c0392b;
        border: 1px solid #f3c0bc;
        border-radius: 12px;
        padding: 12px 16px;
        margin-bottom: 18px;
        font-size: 14px;
        font-weight: 500;
    }

    @@media (max-width: 768px) {
        .register-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="register-wrapper">
    <div class="register-card">
        <div class="register-header">
            <h2>Đăng ký tài khoản</h2>
            <p>Tạo tài khoản để sử dụng hệ thống y tế trực tuyến</p>
        </div>

        <div class="register-body">
            @if (ViewBag.ErrorMessage != null)
            {
                <div class="alert-error">
                    @ViewBag.ErrorMessage
                </div>
            }

            @using (Html.BeginForm("Dangky", "Home", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                <div class="register-grid">
                    <div class="form-group">
                        <label class="form-label">Họ và tên</label>
                        @Html.TextBoxFor(model => model.HoTen, new { @class = "form-control", placeholder = "Nhập họ và tên" })
                        @Html.ValidationMessageFor(model => model.HoTen, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        <label class="form-label">Email</label>
                        @Html.TextBoxFor(model => model.Email, new { @class = "form-control", placeholder = "Nhập email", type = "email" })
                        @Html.ValidationMessageFor(model => model.Email, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        <label class="form-label">Điện thoại</label>
                        @Html.TextBoxFor(model => model.DienThoai, new { @class = "form-control", placeholder = "Nhập số điện thoại" })
                        @Html.ValidationMessageFor(model => model.DienThoai, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        <label class="form-label">Tài khoản</label>
                        @Html.TextBoxFor(model => model.TaiKhoan, new { @class = "form-control", placeholder = "Nhập tên tài khoản" })
                        @Html.ValidationMessageFor(model => model.TaiKhoan, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        <label class="form-label">Mật khẩu</label>
                        @Html.PasswordFor(model => model.MatKhau, new { @class = "form-control", placeholder = "Nhập mật khẩu" })
                        @Html.ValidationMessageFor(model => model.MatKhau, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group">
                        <label class="form-label">Giới tính</label>
                        @Html.DropDownList("IDGioiTinh", null, "Chọn giới tính", new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.IDGioiTinh, "", new { @class = "text-danger" })
                    </div>

                    <div class="form-group" style="grid-column: 1 / -1;">
                        <label class="form-label">Tỉnh / Thành phố</label>
                        @Html.DropDownList("IDTinh", null, "Chọn tỉnh / thành phố", new { @class = "form-control" })
                        @Html.ValidationMessageFor(model => model.IDTinh, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="btn-wrap">
                    <button type="submit" class="btn-submit">Đăng ký</button>
                    <a href="@Url.Action("Dangnhap", "Home")" class="btn-back">Quay lại đăng nhập</a>
                </div>
            }
        </div>
    </div>
</div>