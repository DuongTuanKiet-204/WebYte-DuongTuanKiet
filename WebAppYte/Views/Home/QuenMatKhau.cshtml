@{
    ViewBag.Title = "Quên mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background: linear-gradient(135deg, #eef7fb, #f7fbff);
    }

    .forgot-wrapper {
        min-height: 80vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px 15px;
    }

    .forgot-card {
        width: 100%;
        max-width: 500px;
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 12px 35px rgba(0, 73, 122, 0.12);
        overflow: hidden;
        border: 1px solid #e7f1f8;
    }

    .forgot-header {
        background: linear-gradient(135deg, #1d8cf8, #00b5d8);
        color: white;
        text-align: center;
        padding: 28px 20px;
    }

        .forgot-header h2 {
            margin: 0;
            font-size: 30px;
            font-weight: 700;
        }

        .forgot-header p {
            margin-top: 8px;
            font-size: 14px;
            opacity: 0.95;
        }

    .forgot-body {
        padding: 30px 28px;
    }

    .form-group {
        margin-bottom: 18px;
    }

    .form-label {
        display: block;
        margin-bottom: 8px;
        font-weight: 600;
        color: #1f3b57;
    }

    .form-control {
        width: 100%;
        height: 46px;
        border-radius: 12px;
        border: 1px solid #cfe3f1;
        box-shadow: none;
        padding: 10px 14px;
        font-size: 15px;
    }

        .form-control:focus {
            border-color: #1d8cf8;
            box-shadow: 0 0 0 3px rgba(29, 140, 248, 0.12);
            outline: none;
        }

    .btn-wrap {
        display: flex;
        gap: 12px;
        margin-top: 22px;
        flex-wrap: wrap;
    }

    .btn-submit {
        background: linear-gradient(135deg, #1d8cf8, #00b5d8);
        color: white;
        border: none;
        padding: 12px 22px;
        border-radius: 12px;
        font-size: 15px;
        font-weight: 600;
    }

        .btn-submit:hover {
            color: white;
            background: linear-gradient(135deg, #1878d7, #00a2c2);
        }

    .btn-back {
        background: #eef6fb;
        color: #1f5f8b;
        border: 1px solid #cfe3f1;
        padding: 12px 22px;
        border-radius: 12px;
        font-size: 15px;
        font-weight: 600;
        text-decoration: none;
        display: inline-block;
    }

        .btn-back:hover {
            background: #dff0fb;
            color: #124d77;
            text-decoration: none;
        }

    .alert-custom {
        border-radius: 12px;
        padding: 12px 16px;
        margin-bottom: 18px;
        font-size: 14px;
        font-weight: 500;
    }

    .alert-error {
        background: #fff1f1;
        color: #c0392b;
        border: 1px solid #f3c0bc;
    }

    .note-text {
        margin-top: 18px;
        font-size: 13px;
        color: #6b7d90;
        line-height: 1.6;
        text-align: center;
    }
</style>

<div class="forgot-wrapper">
    <div class="forgot-card">
        <div class="forgot-header">
            <h2>Quên mật khẩu</h2>
            <p>Nhập email đã đăng ký để nhận mã OTP</p>
        </div>

        <div class="forgot-body">
            @if (ViewBag.Error != null)
            {
                <div class="alert-custom alert-error">
                    @ViewBag.Error
                </div>
            }

            @using (Html.BeginForm("GuiOTP", "Home", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" class="form-control" placeholder="Nhập email đã đăng ký" required />
                </div>

                <div class="btn-wrap">
                    <button type="submit" class="btn-submit">Gửi mã OTP</button>
                    <a href="@Url.Action("Dangnhap", "Home")" class="btn-back">Quay lại đăng nhập</a>
                </div>
            }

            <div class="note-text">
                Mã OTP sẽ được gửi tới email thật của bạn.
            </div>
        </div>
    </div>
</div>