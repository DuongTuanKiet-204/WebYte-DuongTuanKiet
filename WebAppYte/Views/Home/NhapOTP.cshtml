@{
    ViewBag.Title = "Nhập OTP";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    body {
        background: linear-gradient(135deg, #eef7ff, #f7fbff);
    }

    .otp-page {
        min-height: 78vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 30px 15px;
    }

    .otp-card {
        width: 100%;
        max-width: 480px;
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 12px 35px rgba(17, 89, 160, 0.12);
        overflow: hidden;
        border: 1px solid #e4eef8;
    }

    .otp-header {
        background: linear-gradient(135deg, #1d8cf8, #00b5d8);
        color: white;
        text-align: center;
        padding: 28px 20px;
    }

        .otp-header h2 {
            margin: 0;
            font-size: 30px;
            font-weight: 700;
        }

        .otp-header p {
            margin: 8px 0 0;
            font-size: 14px;
            opacity: 0.95;
        }

    .otp-body {
        padding: 28px;
    }

    .otp-label {
        display: block;
        margin-bottom: 10px;
        font-weight: 600;
        color: #24425c;
    }

    .otp-input {
        width: 100%;
        height: 48px;
        border: 1px solid #cfe0ef;
        border-radius: 12px;
        padding: 12px 14px;
        font-size: 18px;
        text-align: center;
        letter-spacing: 6px;
        outline: none;
        transition: 0.25s ease;
    }

        .otp-input:focus {
            border-color: #1d8cf8;
            box-shadow: 0 0 0 3px rgba(29, 140, 248, 0.12);
        }

    .otp-btn {
        width: 100%;
        margin-top: 20px;
        border: none;
        border-radius: 12px;
        background: linear-gradient(135deg, #1d8cf8, #00b5d8);
        color: white;
        height: 48px;
        font-size: 16px;
        font-weight: 600;
    }

        .otp-btn:hover {
            background: linear-gradient(135deg, #1878d7, #00a3c3);
            color: white;
        }

    .otp-back {
        display: inline-block;
        margin-top: 16px;
        color: #1d78c1;
        text-decoration: none;
        font-weight: 600;
    }

        .otp-back:hover {
            text-decoration: none;
            color: #125d98;
        }

    .otp-alert {
        border-radius: 12px;
        padding: 12px 14px;
        margin-bottom: 18px;
        font-size: 14px;
        font-weight: 500;
    }

    .otp-alert-error {
        background: #fff1f1;
        color: #c0392b;
        border: 1px solid #f3c0bc;
    }

    .otp-note {
        margin-top: 16px;
        font-size: 13px;
        color: #6b7c8f;
        line-height: 1.6;
        text-align: center;
    }
</style>

<div class="otp-page">
    <div class="otp-card">
        <div class="otp-header">
            <h2>Xác minh OTP</h2>
            <p>Vui lòng nhập mã OTP đã được gửi đến email của bạn</p>
        </div>

        <div class="otp-body">
            @if (ViewBag.Error != null)
            {
                <div class="otp-alert otp-alert-error">
                    @ViewBag.Error
                </div>
            }

            @using (Html.BeginForm("XacNhanOTP", "Home", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                <label class="otp-label">Mã OTP</label>
                <input type="text" name="otp" maxlength="6" class="otp-input" placeholder="------" required />

                <button type="submit" class="otp-btn">Xác nhận OTP</button>
            }

            <div class="otp-note">
                Nếu chưa thấy email, hãy kiểm tra thêm trong mục Spam hoặc Thư rác.
            </div>

            <div style="text-align:center;">
                <a href="@Url.Action("QuenMatKhau", "Home")" class="otp-back">Quay lại quên mật khẩu</a>
            </div>
        </div>
    </div>
</div>